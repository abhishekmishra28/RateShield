{
  "name": "rateshield",
  "version": "1.0.0",
  "description": "Standalone API Rate Limiting Service — protects APIs from abuse, excessive traffic, bot attacks, and rate-limit violations.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest src/tests/unit --forceExit",
    "test:integration": "jest src/tests/integration --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit --detectOpenHandles",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down -v",
    "docker:logs": "docker compose logs -f app"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abhishekmishra28/RateShield.git"
  },
  "keywords": [
    "rate-limiter",
    "api-gateway",
    "token-bucket",
    "sliding-window",
    "redis",
    "express",
    "node"
  ],
  "author": "Abhishek Mishra",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/abhishekmishra28/RateShield/issues"
  },
  "homepage": "https://github.com/abhishekmishra28/RateShield#readme",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "prisma": "^6.19.3",
    "redis": "^6.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2"
  }
}
